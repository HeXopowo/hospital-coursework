<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="hospital.view.controller.AdminController"
      spacing="5" prefWidth="1000" prefHeight="600">

    <MenuBar>
        <Menu text="Действия">
            <MenuItem text="Приёмы" onAction="#handleAllAppointments"/>
            <MenuItem text="Управление врачами" onAction="#handleManageDoctors"/>
            <MenuItem text="Управление пациентами" onAction="#handleManagePatients"/>
        </Menu>
    </MenuBar>

    <TabPane fx:id="adminTabPane" VBox.vgrow="ALWAYS">
        <tabs>
            <!-- Вкладка "Врачи" -->
            <Tab text="Врачи" closable="false">
                <VBox spacing="5">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Поиск врачей:"/>
                        <TextField fx:id="searchDoctorsField" promptText="Поиск по ФИО врача или специальности..." prefWidth="250"/>
                        <Button text="Обновить" onAction="#handleRefreshDoctors"/>
                    </HBox>
                    <TableView fx:id="doctorsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="doctorIdColumn" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="doctorFirstNameColumn" text="Имя" prefWidth="100"/>
                            <TableColumn fx:id="doctorLastNameColumn" text="Фамилия" prefWidth="100"/>
                            <TableColumn fx:id="specializationColumn" text="Специализация" prefWidth="120"/>
                            <TableColumn fx:id="roomColumn" text="Кабинет" prefWidth="80"/>
                            <TableColumn fx:id="scheduleColumn" text="Расписание" prefWidth="120"/>
                            <TableColumn fx:id="doctorEmailColumn" text="Email" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Вкладка "Пациенты" -->
            <Tab text="Пациенты" closable="false">
                <VBox spacing="5">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Поиск пациентов:"/>
                        <TextField fx:id="searchPatientsField" promptText="Поиск по ФИО пациента..." prefWidth="250"/>
                        <Button text="Обновить" onAction="#handleRefreshPatients"/>
                    </HBox>
                    <TableView fx:id="patientsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="patientIdColumn" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="patientFirstNameColumn" text="Имя" prefWidth="100"/>
                            <TableColumn fx:id="patientLastNameColumn" text="Фамилия" prefWidth="100"/>
                            <TableColumn fx:id="birthDateColumn" text="Дата рождения" prefWidth="100"/>
                            <TableColumn fx:id="phoneColumn" text="Телефон" prefWidth="120"/>
                            <TableColumn fx:id="patientEmailColumn" text="Email" prefWidth="150"/>
                            <TableColumn fx:id="snilsColumn" text="СНИЛС" prefWidth="120"/>
                            <TableColumn fx:id="policyColumn" text="Полис ОМС" prefWidth="120"/>
                            <TableColumn fx:id="districtColumn" text="Участок" prefWidth="80"/>
                            <TableColumn fx:id="addressColumn" text="Адрес" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Вкладка "Учёт пациентов" -->
            <Tab text="Учёт пациентов" closable="false">
                <VBox spacing="5">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Активные учётные записи пациентов:"/>
                        <Button text="Обновить" onAction="#handleRefreshRegistrations"/>
                    </HBox>
                    <TableView fx:id="registrationsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="regPatientColumn" text="Пациент" prefWidth="200"/>
                            <TableColumn fx:id="regDoctorColumn" text="Врач" prefWidth="200"/>
                            <TableColumn fx:id="regDateColumn" text="Дата постановки" prefWidth="120"/>
                            <TableColumn fx:id="regNotesColumn" text="Примечания" prefWidth="200"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Вкладка "Архив" -->
            <Tab text="Архив" closable="false">
                <VBox spacing="10">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Архивированные пациенты:"/>
                        <Button text="Обновить" onAction="#handleRefreshArchive"/>
                    </HBox>
                    <TableView fx:id="archivedPatientsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="archPatIdColumn" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="archPatFirstNameColumn" text="Имя" prefWidth="100"/>
                            <TableColumn fx:id="archPatLastNameColumn" text="Фамилия" prefWidth="100"/>
                            <TableColumn fx:id="archPatBirthDateColumn" text="Дата рождения" prefWidth="100"/>
                            <TableColumn fx:id="archPatPhoneColumn" text="Телефон" prefWidth="120"/>
                            <TableColumn fx:id="archPatEmailColumn" text="Email" prefWidth="150"/>
                            <TableColumn fx:id="archPatSnilsColumn" text="СНИЛС" prefWidth="120"/>
                            <TableColumn fx:id="archPatPolicyColumn" text="Полис ОМС" prefWidth="120"/>
                            <TableColumn fx:id="archPatDistrictColumn" text="Участок" prefWidth="80"/>
                            <TableColumn fx:id="archPatAddressColumn" text="Адрес" prefWidth="150"/>
                            <TableColumn fx:id="archPatDateColumn" text="Дата архивации" prefWidth="150"/>
                            <TableColumn fx:id="archPatActionColumn" text="Действие" prefWidth="100"/>
                        </columns>
                    </TableView>
                    <Separator/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Архивированные врачи:"/>
                        <!-- Кнопка обновления уже есть выше, обновляет обе таблицы -->
                    </HBox>
                    <TableView fx:id="archivedDoctorsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="archDocIdColumn" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="archDocFirstNameColumn" text="Имя" prefWidth="100"/>
                            <TableColumn fx:id="archDocLastNameColumn" text="Фамилия" prefWidth="100"/>
                            <TableColumn fx:id="archDocSpecializationColumn" text="Специализация" prefWidth="120"/>
                            <TableColumn fx:id="archDocRoomColumn" text="Кабинет" prefWidth="80"/>
                            <TableColumn fx:id="archDocScheduleColumn" text="Расписание" prefWidth="120"/>
                            <TableColumn fx:id="archDocEmailColumn" text="Email" prefWidth="150"/>
                            <TableColumn fx:id="archDocDateColumn" text="Дата архивации" prefWidth="150"/>
                            <TableColumn fx:id="archDocActionColumn" text="Действие" prefWidth="100"/>
                        </columns>
                    </TableView>
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="Очистить архив (удалить записи старше 50 лет)" onAction="#handleCleanupArchive"/>
                    </HBox>
                </VBox>
            </Tab>
        </tabs>
    </TabPane>
</VBox>