<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="hospital.view.controller.MedicalRecordsController"
      spacing="10"
      prefWidth="1200"
      prefHeight="700">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <Label fx:id="titleLabel" text="Медицинские записи" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <!-- Панель поиска -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Поиск:"/>
        <TextField fx:id="searchField" promptText="Поиск по ФИО..." prefWidth="300"/>
    </HBox>

    <!-- Таблица медицинских записей -->
    <TableView fx:id="recordsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="dateColumn" text="Дата создания" prefWidth="100"/>
            <TableColumn fx:id="personColumn" text="Врач/Пациент" prefWidth="150"/>
            <TableColumn fx:id="diseaseHistoryColumn" text="Анамнез заболевания" prefWidth="250"/>
            <TableColumn fx:id="diagnosisColumn" text="Диагноз" prefWidth="200"/>
            <TableColumn fx:id="recommendationsColumn" text="Рекомендации" prefWidth="250"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <!-- Кнопки управления для врача -->
    <HBox fx:id="doctorButtonsPanel" spacing="10" visible="false" managed="false">
        <Button fx:id="addRecordButton" text="Добавить запись" onAction="#handleAddRecord"/>
        <Button fx:id="editRecordButton" text="Изменить" onAction="#handleEditRecord"/>
        <Button fx:id="deleteRecordButton" text="Удалить" onAction="#handleDeleteRecord"/>
    </HBox>
</VBox>